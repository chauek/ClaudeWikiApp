{
  "name": "claudewiki",
  "version": "0.2.1",
  "description": "Personal knowledge base viewer",
  "main": "./out/main/index.js",
  "author": "Chauek",
  "private": true,
  "scripts": {
    "postinstall": "electron-rebuild -f -w node-pty",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "dist": "electron-vite build && electron-builder --mac"
  },
  "build": {
    "appId": "com.chauek.claudewiki",
    "productName": "ClaudeWiki",
    "directories": {
      "output": "dist-electron"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "ClaudeWiki ${version}"
    },
    "extraResources": [
      {
        "from": "resources/wiki-scaffold",
        "to": "wiki-scaffold"
      }
    ],
    "icon": "build/icon.icns",
    "npmRebuild": false
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^3.6.0",
    "d3-force": "^3.0.0",
    "electron-store": "^8.2.0",
    "gray-matter": "^4.0.3",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
